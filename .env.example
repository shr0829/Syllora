# Syllora experience deployment environment variables
# Railway single-service deployment can leave VITE_API_BASE_URL empty
# because the backend serves the built frontend on the same domain.

# Optional for split frontend/backend deployment only
VITE_API_BASE_URL=

# Text model
LEARNING_MODEL_PROVIDER=OpenAI
LEARNING_BASE_URL=https://api.asxs.top/v1
LEARNING_WIRE_API=responses
LEARNING_API_KEY=YOUR_TEXT_API_KEY
LEARNING_MODEL=gpt-5.4
LEARNING_REVIEW_MODEL=gpt-5.4
LEARNING_MODEL_REASONING_EFFORT=xhigh
LEARNING_DISABLE_RESPONSE_STORAGE=true
LEARNING_NETWORK_ACCESS=enabled
LEARNING_WINDOWS_WSL_SETUP_ACKNOWLEDGED=true
LEARNING_MODEL_CONTEXT_WINDOW=1000000
LEARNING_MODEL_AUTO_COMPACT_TOKEN_LIMIT=900000
LEARNING_REQUIRES_OPENAI_AUTH=true

# Image model
LEARNING_IMAGE_MODEL=gpt-image-2
LEARNING_IMAGE_BASE_URL=https://4sapi.com
LEARNING_IMAGE_API_KEY=YOUR_IMAGE_API_KEY

# Optional secondary image channel fallback
LEARNING_IMAGE_CHANNEL_2_TYPE=newapi_channel_conn
LEARNING_IMAGE_CHANNEL_2_BASE_URL=https://xcode.best
LEARNING_IMAGE_CHANNEL_2_API_KEY=YOUR_SECONDARY_IMAGE_API_KEY
LEARNING_IMAGE_CHANNEL_2_MODEL_ID=gpt-image-2

# Runtime
HOST=0.0.0.0
PORT=8000
